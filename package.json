{
  "name": "otter-music",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "shared",
    "functions"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" ",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npx wrangler pages dev frontend/out --ip 0.0.0.0 --port 8080",
    "build": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wrangler": "^4.24.0"
  }
}
